# ---- App ----
APP_NAME=BharatShop
APP_VERSION=1.0.0
DEBUG=false
# Public site URL (used in email links)
FRONTEND_URL=http://localhost:5173
# Comma-separated dev origins for CORS in LOCAL cross-port dev only.
# Leave EMPTY in production (FE + BE share one Vercel domain, no CORS).
DEV_ALLOWED_ORIGINS=http://localhost:5173

# ---- Admin seed (used by seed_admin.py) ----
ADMIN_EMAIL=you@yourdomain.com
ADMIN_PASSWORD=change-me-strong

# ---- Security ----
SECRET_KEY=your-super-secret-jwt-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- Google OAuth ----
GOOGLE_CLIENT_ID=

# ---- Firebase OTP Auth ----
FIREBASE_PROJECT_ID=

# ---- Database ----
# Use Neon's POOLED connection string for serverless (host contains "-pooler").
# Driver MUST be asyncpg.
DATABASE_URL=postgresql+asyncpg://user:pass@ep-xxxx-pooler.region.aws.neon.tech/bharatshop
DB_ECHO=false

# ---- Razorpay ----
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxx

# ---- Shiprocket ----
SHIPROCKET_EMAIL=your@email.com
SHIPROCKET_PASSWORD=yourpassword
SHIPROCKET_PICKUP_PINCODE=395007

# ---- Images (Postgres BYTEA; no Cloudinary) ----
MAX_IMAGE_UPLOAD_MB=5
IMAGE_ALLOWED_TYPES=image/jpeg,image/png,image/webp

# ---- Email (Resend) ----
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=orders@yourdomain.com
