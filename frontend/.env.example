# Prod: leave unset — FE + BE share the Vercel domain, so the app calls "/api".
# Local: point at the local FastAPI server (or rely on the vite dev proxy to /api).
VITE_API_URL=
VITE_APP_NAME=BharatShop
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx

# ---- Firebase (Google + Phone/OTP login) ----
# Get these from Firebase Console -> Project settings -> General -> Your apps (Web app).
# ALL of API_KEY, AUTH_DOMAIN, PROJECT_ID, APP_ID are REQUIRED — if any is blank the
# app uses MOCK login (OTP code 123456) instead of throwing auth/configuration-not-found.
# Also: enable Google + Phone providers in Authentication -> Sign-in method, and add
# your domain (+ localhost) under Authentication -> Settings -> Authorized domains.
# Leave ALL blank to use mock login for now.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional: only needed if you verify Google tokens by client id on the backend.
VITE_GOOGLE_CLIENT_ID=

# ---- Analytics (Phase 8) ----
# PostHog — product analytics, session replay, funnels.
# Sign up at https://posthog.com → Project Settings → Project API Key.
# Leave blank to disable PostHog entirely (no errors, no tracking).
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Google Analytics 4 — page views + ecommerce events.
# Create a GA4 property → Web Data Stream → copy the Measurement ID (G-XXXXXXXXXX).
# Leave blank to disable GA4 entirely.
VITE_GA_MEASUREMENT_ID=
